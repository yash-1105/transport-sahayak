# Transport Sahayak — environment variable template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# ── Gemini (severity engine — classification escalation + hazard-signal extraction) ──
# Get a key at: https://aistudio.google.com/app/apikey
# Link it to a GCP project with billing to draw from Google Cloud credits — the free
# tier often has a 0-request quota, which fails closed (see below), not silently.
# This is consumed by the Python severity engine (severity_engine/gemini_client.py),
# NOT by the Next.js app directly — set it in the engine's own environment (local .env
# at the repo root for `uvicorn app:app`, or as a Railway env var in production), not
# just here. Severity scoring and agency dispatch are always rule-based regardless;
# Gemini only reads free text — it never decides what gets dispatched. Without this
# key, the engine falls back to rules-only classification and whatever explicit
# signals (quick-flags) the reporter provided — never fabricated, never blocks.
GEMINI_API_KEY=AIza...

# ── Google Maps — browser key ─────────────────────────────────────────────────
# Used client-side by @vis.gl/react-google-maps for the map tile layer only.
# Restrictions in Google Cloud Console:
#   Application restriction: HTTP referrers
#   Allowed referrers: localhost:3000/*, *.your-production-domain.in/*
#   API restriction: Maps JavaScript API only
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=AIza...

# ── Google Maps — server key ─────────────────────────────────────────────────
# Used exclusively in Next.js route handlers (/api/routes/*, /api/places/*).
# NEVER prefix with NEXT_PUBLIC_ — must never reach the browser.
# Restrictions in Google Cloud Console:
#   Application restriction: IP addresses (server IPs for production, none for dev)
#   API restriction: Routes API, Places API (New), Geocoding API
GOOGLE_MAPS_SERVER_KEY=AIza...

# ── Voice streaming (Google Cloud Speech-to-Text V2 / Chirp) ──────────────────
# The browser connects DIRECTLY to the Python severity-engine's WebSocket
# endpoint (/ws/voice) to stream microphone audio — Vercel serverless
# functions can't hold a WebSocket open, so this is NOT proxied through the
# Next.js app. Point it at the same Railway deployment as SEVERITY_ENGINE_URL,
# with wss:// instead of https:// and the /ws/voice path.
#   Local dev:  ws://localhost:8000/ws/voice
#   Production: wss://<your-railway-domain>/ws/voice
# The actual Speech-to-Text credentials (GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 /
# GOOGLE_SERVICE_ACCOUNT_JSON) are configured on the Python engine itself
# (Railway env vars), NOT here — see severity_engine/voice_stream.py.
NEXT_PUBLIC_VOICE_STREAM_URL=ws://localhost:8000/ws/voice

# ── Supabase (pothole database) ───────────────────────────────────────────────
# Create a free project at https://supabase.com, then find these in:
#   Project Settings → API → Project URL and anon/public key
# Both are safe to expose (anon key is protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
