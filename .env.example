# Transport Sahayak — environment variable template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# ── Gemini (severity engine — classification escalation + hazard-signal extraction) ──
# Get a key at: https://aistudio.google.com/app/apikey
# Link it to a GCP project with billing to draw from Google Cloud credits — the free
# tier often has a 0-request quota, which fails closed (see below), not silently.
# This is consumed by the Python severity engine (severity_engine/gemini_client.py),
# NOT by the Next.js app directly — set it in the engine's own environment (local .env
# at the repo root for `uvicorn app:app`, or as a Railway env var in production), not
# just here. Severity scoring and agency dispatch are always rule-based regardless;
# Gemini only reads free text — it never decides what gets dispatched. Without this
# key, the engine falls back to rules-only classification and whatever explicit
# signals (quick-flags) the reporter provided — never fabricated, never blocks.
GEMINI_API_KEY=AIza...

# ── Google Maps — browser key ─────────────────────────────────────────────────
# Used client-side by @vis.gl/react-google-maps for the map tile layer only.
# Restrictions in Google Cloud Console:
#   Application restriction: HTTP referrers
#   Allowed referrers: localhost:3000/*, *.your-production-domain.in/*
#   API restriction: Maps JavaScript API only
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=AIza...

# ── Google Maps — server key ─────────────────────────────────────────────────
# Used exclusively in Next.js route handlers (/api/routes/*, /api/places/*).
# NEVER prefix with NEXT_PUBLIC_ — must never reach the browser.
# Restrictions in Google Cloud Console:
#   Application restriction: IP addresses (server IPs for production, none for dev)
#   API restriction: Routes API, Places API (New), Geocoding API
GOOGLE_MAPS_SERVER_KEY=AIza...

# ── Voice streaming (Google Cloud Speech-to-Text V2 / Chirp) ──────────────────
# The browser connects DIRECTLY to the Python severity-engine's WebSocket
# endpoint (/ws/voice) to stream microphone audio — Vercel serverless
# functions can't hold a WebSocket open, so this is NOT proxied through the
# Next.js app. Point it at the same Railway deployment as SEVERITY_ENGINE_URL,
# with wss:// instead of https:// and the /ws/voice path.
#   Local dev:  ws://localhost:8000/ws/voice
#   Production: wss://<your-railway-domain>/ws/voice
# The actual Speech-to-Text credentials (GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 /
# GOOGLE_SERVICE_ACCOUNT_JSON) are configured on the Python engine itself
# (Railway env vars), NOT here — see severity_engine/voice_stream.py.
NEXT_PUBLIC_VOICE_STREAM_URL=ws://localhost:8000/ws/voice

# ── Voice dispatcher (Gemini Live via Vertex AI) ──────────────────────────────
# The "Voice" tab (distinct from "Speech-to-Text" above) — a full conversational
# AI call-taker, not just transcription. Same reasoning as
# NEXT_PUBLIC_VOICE_STREAM_URL: the browser connects DIRECTLY to the Python
# engine's WebSocket, bypassing Vercel.
#   Local dev:  ws://localhost:8000/ws/dispatcher
#   Production: wss://<your-railway-domain>/ws/dispatcher
NEXT_PUBLIC_DISPATCHER_WS_URL=ws://localhost:8000/ws/dispatcher
# Vertex AI region for the Live API — verified working with us-central1 and
# gemini-live-2.5-flash-native-audio during development. Uses the SAME
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 / GOOGLE_SERVICE_ACCOUNT_JSON / local-file
# credentials as the Speech-to-Text setup above — no new credential vars.
VERTEX_AI_LOCATION=us-central1
# Usually unnecessary — defaults to the service account JSON's own project_id.
GOOGLE_CLOUD_PROJECT=
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio

# ── Sarvam AI (HINDI voice dispatcher only — Saaras STT + Bulbul TTS) ─────────
# The hi-IN "Voice" tab conversation runs on Sarvam Saaras v3 (streaming
# speech-to-text) and Bulbul v3 (streaming text-to-speech), with the existing
# Gemini (text) doing all reasoning — see severity_engine/dispatcher_hindi.py.
# English (en-IN) does NOT use Sarvam and is unaffected by these.
# Get a key at: https://dashboard.sarvam.ai — set these in the Python engine's
# environment (repo-root .env for `uvicorn app:app`, or Railway env vars).
SARVAM_API_KEY=
# Model names accept both "saaras:v3" and "saaras-v3" spellings.
SARVAM_STT_MODEL=saaras-v3
SARVAM_TTS_MODEL=bulbul-v3
# "shubh" (male) is the current choice, per user preference after comparing
# voices in Sarvam's playground -- any Bulbul v3 speaker works technically,
# but if you change gender here, also update the self-referential grammar in
# dispatcher_hindi.py's system prompt (पुल्लिंग/स्त्रीलिंग verb forms) to match.
SARVAM_TTS_SPEAKER=shubh
# Bulbul v3 does NOT support pitch/loudness/SSML (verified against Sarvam's
# docs) -- these are the real tunable params. Lower buffer/chunk sizes trade a
# little prosody smoothness for a faster time-to-first-audio-chunk; raise
# them back toward Sarvam's own recommended max (150 chars) if speech still
# sounds choppy, at the cost of a slightly slower time-to-first-audio.
SARVAM_TTS_PACE=1.2
SARVAM_TTS_TEMPERATURE=0.7
SARVAM_TTS_MIN_BUFFER_CHARS=50
SARVAM_TTS_MAX_CHUNK_CHARS=150
# Optional: only set if speaker echo (no headphones) false-triggers a
# barge-in interruption in the field. saaras:v3-only VAD parameter.
SARVAM_STT_INTERRUPT_MIN_FRAMES=
# Set to "false" to silence the per-turn latency breakdown
# ([latency] gemini_r0=...ms tts_first_chunk=...ms turn_total=...ms) logged
# by severity_engine/dispatcher_hindi.py — on by default, useful in prod too
# since it's one INFO log line per turn, not per-request tracing.
HINDI_LATENCY_LOG=true
# Text-reasoning Gemini model for the Hindi dispatcher (runs on the same
# Vertex AI service-account credentials as the English Live dispatcher).
# gemini-2.0-flash is no longer served on Vertex us-central1 — use 2.5-flash.
GEMINI_TEXT_MODEL=gemini-2.5-flash

# ── Supabase (pothole database) ───────────────────────────────────────────────
# Create a free project at https://supabase.com, then find these in:
#   Project Settings → API → Project URL and anon/public key
# Both are safe to expose (anon key is protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
